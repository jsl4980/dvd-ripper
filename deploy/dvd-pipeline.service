[Unit]
Description=DVD to Plex pipeline (FastAPI + workers)
Documentation=https://github.com/
After=network-online.target
Wants=network-online.target
RequiresMountsFor=/mnt/plex

[Service]
Type=simple
User=dvdrip
Group=dvdrip
WorkingDirectory=/opt/dvd-ripper
Environment=PATH=/opt/dvd-ripper/.venv/bin:/usr/local/bin:/usr/bin
EnvironmentFile=-/etc/dvd-pipeline.env
ExecStart=/opt/dvd-ripper/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
