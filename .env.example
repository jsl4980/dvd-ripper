# Copy to .env and fill in. .env is gitignored.

# Environment: dev | prod
APP_ENV=dev

# Storage: STAGING_DIR local (rips + temp encodes). LIBRARY_ROOT = final Plex tree
# (often an SMB UNC on Windows, e.g. //raspberrypi/pishare — use // not \\ so \r is not parsed as CR).
STAGING_DIR=./staging
LIBRARY_ROOT=./library
DB_PATH=./pipeline.db

# External binaries.
# On Windows: makemkvcon64.exe / HandBrakeCLI.exe / ffprobe.exe (or full paths)
# On Linux: makemkvcon / HandBrakeCLI / ffprobe (on PATH)
MAKEMKVCON_PATH=makemkvcon
HANDBRAKECLI_PATH=HandBrakeCLI
FFPROBE_PATH=ffprobe
FFMPEG_PATH=ffmpeg

# Use the mock binary in tests/fixtures/mock_makemkvcon for end-to-end dev testing
# without a real DVD drive. Uncomment and adjust:
# MAKEMKVCON_PATH=./tests/fixtures/mock_makemkvcon/mock_makemkvcon.py
# ALLOW_MOCK_MAKEMKVCON=true

# DVD device (Linux: /dev/sr0, Windows: drive letter like D:)
DVD_DEVICE=/dev/sr0

# Encoder profile: nvenc_h264 (default) | nvenc_h265 | x265
ENCODER_PROFILE=nvenc_h264
ENCODER_QUALITY=20
ENCODER_PRESET=slow
AUDIO_FALLBACK_BITRATE=160

# Metadata APIs
TMDB_API_KEY=
TVDB_API_KEY=

# Plex
PLEX_URL=http://plex-host:32400
PLEX_TOKEN=
PLEX_MOVIES_SECTION_ID=1
PLEX_TV_SECTION_ID=2

# For Plex "partial scan", paths under LIBRARY_ROOT must be under PLEX_PATH_LOCAL too.
# Windows UNC example: local = //server/share, remote = /mnt/usb/Plex (same root on the Pi).
PLEX_PATH_LOCAL=/mnt/plex
PLEX_PATH_REMOTE=/mnt/plex

# Web server
HOST=0.0.0.0
PORT=8000
